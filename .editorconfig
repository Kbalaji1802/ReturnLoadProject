# Root EditorConfig for ReturnLoadPlatform (monorepo baseline).
# Per-stack overrides live in admin/.editorconfig and backend/.editorconfig
# (each `root = true`, so they fully own their folders). This file governs
# everything else: /ai, /mobile, /database, /docker, /docs, /scripts.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.dart]
indent_size = 2
max_line_length = 80

[*.md]
# Preserve trailing spaces in Markdown (hard line breaks).
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2

[Makefile]
indent_style = tab
