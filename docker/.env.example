# Copy this file to `.env` in the same folder and adjust values.
# The real `.env` is git-ignored (01_PROJECT_RULES.md §1) — never commit secrets.

# --- PostgreSQL / PostGIS -------------------------------------------------
POSTGRES_USER=returnload
POSTGRES_PASSWORD=returnload
POSTGRES_DB=returnload
POSTGRES_PORT=5432

# --- API ------------------------------------------------------------------
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Development

# --- Auth (framework only for now) ---------------------------------------
# Supply a strong, random secret (32+ bytes) once authentication is implemented
# (M2). Required outside Development — the API fails to start without it there.
JWT_SIGNING_KEY=

# --- Security / CORS (M1.5) -----------------------------------------------
# Comma/JSON list of browser origins allowed to call the API. Empty = none.
# Example: https://admin.returnload.example
CORS_ALLOWED_ORIGINS=
