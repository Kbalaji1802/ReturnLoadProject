{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "//": "Real connection strings are supplied via environment (ConnectionStrings__ReturnLoadDatabase) or appsettings.Development.json. Never commit production credentials (01_PROJECT_RULES.md §1).",
    "ReturnLoadDatabase": ""
  },
  "Jwt": {
    "//": "Framework wiring only (no token issuance yet). SigningKey MUST come from a secret store / environment variable in real environments; startup fails outside Development if it is missing.",
    "Issuer": "https://returnload.local",
    "Audience": "returnload-clients",
    "SigningKey": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Security": {
    "//": "M1.5 hardening. HttpsRedirection/Hsts apply outside Development.",
    "HttpsRedirection": true,
    "Hsts": true,
    "SecurityHeaders": true,
    "ContentSecurityPolicy": "default-src 'none'; frame-ancestors 'none'"
  },
  "Cors": {
    "//": "Explicit allowlist. Empty = no cross-origin browser access. Set per environment / CORS_ALLOWED_ORIGINS.",
    "AllowedOrigins": [],
    "AllowCredentials": false
  },
  "RateLimiting": {
    "Global": { "PermitLimit": 100, "WindowSeconds": 60, "QueueLimit": 0 },
    "Sensitive": { "PermitLimit": 10, "WindowSeconds": 60, "QueueLimit": 0 }
  },
  "RequestLimits": {
    "MaxRequestBodyBytes": 10485760
  },
  "FileUpload": {
    "MaxFileSizeBytes": 10485760,
    "AllowedMimeTypes": [ "application/pdf", "image/jpeg", "image/png" ],
    "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png" ]
  },
  "FileStorage": {
    "//": "Local-disk dev backend (ADR-0012). A cloud object store replaces this later.",
    "RootPath": "storage",
    "PublicBaseUrl": "http://localhost/files"
  },
  "PasswordPolicy": {
    "MinLength": 12,
    "MaxLength": 128,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireNonAlphanumeric": true
  },
  "AllowedHosts": "*"
}
