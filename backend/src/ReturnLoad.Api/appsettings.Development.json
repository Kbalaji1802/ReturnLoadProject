{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "//": "Local development database. Matches the defaults in docker/docker-compose.yml. These are LOCAL dev credentials only, never production secrets.",
    "ReturnLoadDatabase": "Host=localhost;Port=5432;Database=returnload;Username=returnload;Password=returnload"
  }
}
